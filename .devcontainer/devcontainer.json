{
  "name": "aiwrite",
  "image": "mcr.microsoft.com/devcontainers/ruby:4.0",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "bundle install && npm install -g @google/gemini-cli",
  "forwardPorts": [8080],
  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
